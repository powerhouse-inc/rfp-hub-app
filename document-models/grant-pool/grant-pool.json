              "template": "",
              "reducer": "const idx = state.tags.indexOf(action.input.tag);\nif (idx === -1) {\n  throw new TagNotFoundError(`Tag ${action.input.tag} not found`);\n}\nstate.tags.splice(idx, 1);",
              "errors": [
