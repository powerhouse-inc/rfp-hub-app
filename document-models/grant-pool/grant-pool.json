              "name": "REMOVE_CATEGORY",
              "description": "",
              "schema": "input RemoveCategoryInput {\n    category: String!\n}",
              "template": "",
              "reducer": "const idx = state.categories.indexOf(action.input.category);\nif (idx === -1) {\n  throw new CategoryNotFoundError(`Category ${action.input.category} not found`);\n}\nstate.categories.splice(idx, 1);",
              "errors": [
                {
                  "id": "err-gp-category-not-found",
                  "name": "CategoryNotFoundError",
                  "code": "CATEGORY_NOT_FOUND",
                  "description": "Category not found.",
                  "template": ""
                }
              ],
              "examples": [],
