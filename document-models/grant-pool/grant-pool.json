              "template": "",
              "reducer": "if (state.ecosystems.includes(action.input.ecosystem)) {\n  throw new DuplicateEcosystemError(`Ecosystem ${action.input.ecosystem} already present`);\n}\nstate.ecosystems.push(action.input.ecosystem);",
              "errors": [
                {
