              "name": "ADD_CATEGORY",
              "description": "",
              "schema": "input AddCategoryInput {\n    category: String!\n}",
              "template": "",
              "reducer": "if (state.categories.includes(action.input.category)) {\n  throw new DuplicateCategoryError(`Category ${action.input.category} already present`);\n}\nstate.categories.push(action.input.category);",
              "errors": [
                {
                  "id": "err-gp-duplicate-category",
                  "name": "DuplicateCategoryError",
                  "code": "DUPLICATE_CATEGORY",
                  "description": "Category already present.",
                  "template": ""
                }
              ],
              "examples": [],
              "scope": "global"
            },
            {
